#!/bin/bash
cd "$(dirname "$0")"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Force-syncing the latest config from GitHub"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# 1. 检查本地状态
echo "Checking local changes..."
if ! git diff --quiet || ! git diff --cached --quiet; then
    echo ""
    echo "⚠️  Warning: uncommitted local changes were detected."
    echo "Force pull will overwrite those uncommitted local changes."
    read -p "Discard local changes and force-sync anyway? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Operation canceled"
        exit 0
    fi
fi

# 2. 执行强制同步
echo "Fetching from remote..."
git fetch origin main

echo "Hard-resetting local branch..."
git reset --hard origin/main

echo ""
echo "Importing dynamic_freq sync snapshot..."
python3 scripts/import-dynamic-freq.py || exit 1
echo "✓ dynamic_freq imported"

# 3. 清理可能多出的未跟踪文件（可选，保持纯净）
# git clean -fd  # 如果你想彻底保持和远程一模一样，可以取消注释这一行

echo ""
echo "✓ All config files are now up to date."
