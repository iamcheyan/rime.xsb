#!/bin/bash
# Rime 输入法重建脚本
# 功能：删除 build 目录并重新编译所有配置
# 注意：会自动备份和恢复扩展词库文件（*.extended.*）

# 注意：不使用 set -e，因为 macOS 上可能没有某些命令
set -u

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# 脚本所在目录（scripts 目录）
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# Rime 配置目录（scripts 的父目录，或使用第一个参数）
RIME_DIR="${1:-$SCRIPT_DIR}"
BUILD_DIR="$RIME_DIR/build"
SHARED_DATA_DIR="$RIME_DIR/shared-data"

if [ ! -d "$SHARED_DATA_DIR" ]; then
    if [ -d "/usr/share/rime-data" ]; then
        SHARED_DATA_DIR="/usr/share/rime-data"
    else
        SHARED_DATA_DIR=""
    fi
fi

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}Rime Rebuild Script${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

# 检查目录是否存在
if [ ! -d "$RIME_DIR" ]; then
    echo -e "${RED}Error: config directory does not exist: $RIME_DIR${NC}"
    exit 1
fi

echo -e "${YELLOW}Config directory: $RIME_DIR${NC}"
echo ""

# 检查 build 目录是否存在
BACKUP_DIR="/tmp/rime_build_backup_$$"
EXTENDED_FILES_RESTORED=false

if [ -d "$BUILD_DIR" ]; then
    # 计算 build 目录大小
    BUILD_SIZE=$(du -sh "$BUILD_DIR" 2>/dev/null | cut -f1)
    echo -e "${YELLOW}Detected build directory, size: $BUILD_SIZE${NC}"
    
    # 备份扩展词库文件（如果存在）
    EXTENDED_FILES=$(find "$BUILD_DIR" -name "*.extended.*" -type f 2>/dev/null)
    if [ -n "$EXTENDED_FILES" ]; then
        echo -e "${YELLOW}Detected extended dictionary files, backing up...${NC}"
        mkdir -p "$BACKUP_DIR"
        BACKUP_COUNT=0
        while IFS= read -r file; do
            if [ -f "$file" ]; then
                RELATIVE_PATH="${file#$BUILD_DIR/}"
                BACKUP_PATH="$BACKUP_DIR/$RELATIVE_PATH"
                mkdir -p "$(dirname "$BACKUP_PATH")"
                if cp "$file" "$BACKUP_PATH" 2>/dev/null; then
                    echo -e "  ${GREEN}✓ Backed up: $(basename "$file")${NC}"
                    BACKUP_COUNT=$((BACKUP_COUNT + 1))
                fi
            fi
        done <<< "$EXTENDED_FILES"
        if [ "$BACKUP_COUNT" -gt 0 ]; then
            echo -e "${GREEN}✓ Extended dictionary backup complete ($BACKUP_COUNT file(s))${NC}"
        fi
    fi
    
    echo -e "${YELLOW}Removing build directory...${NC}"
    rm -rf "$BUILD_DIR"
    echo -e "${GREEN}✓ Build directory removed${NC}"
else
    echo -e "${YELLOW}Build directory does not exist, skipping removal${NC}"
fi

# 链接 Rime 配置文件到系统目录
link_rime_config() {
    echo -e "${CYAN}Checking system Rime config symlinks...${NC}"
    
    # 目标路径列表
    local targets=(
        "$HOME/.config/ibus/rime"
        "$HOME/.var/app/org.fcitx.Fcitx5/data/fcitx5/rime"
        "$HOME/.local/share/fcitx5/rime"
        "$HOME/.config/fcitx/rime"
        "$HOME/Library/Rime"
    )
    
    for target in "${targets[@]}"; do
        # 检查目标目录的父目录是否存在（判断是否安装了对应的框架）
        if [ -d "$(dirname "$target")" ]; then
            # 1. 检查是否已经是正确的软链接
            if [ -L "$target" ]; then
                local current_src=$(readlink "$target")
                # 简单检查链接目标是否匹配
                if [[ "$current_src" == "$RIME_DIR" ]]; then
                   echo -e "  ${GREEN}✓ [linked] $target${NC}"
                   continue
                fi
            fi
            
            # 2. 如果存在（无论是文件、目录还是失效链接），处理备份或清理
            if [ -L "$target" ] || [ -e "$target" ]; then
                # 如果是真实目录或文件（非链接），则备份
                if [ ! -L "$target" ]; then
                    local backup_path="${target}.backup.$(date +%Y%m%d_%H%M%S)"
                    echo -e "  ${YELLOW}⚠ Existing config found (not a symlink), backing up to: $backup_path${NC}"
                    mv "$target" "$backup_path"
                else
                    # 如果是错误的链接（包括失效链接），直接删除
                    echo -e "  ${YELLOW}⚠ Broken or incorrect symlink found, removing...${NC}"
                    rm "$target"
                fi
            fi
            
            # 3. 创建软链接 (使用 -sfn 强制更新，或者先 rm 后 ln)
            echo -e "  ${YELLOW}Creating symlink: $target -> $RIME_DIR${NC}"
            if ln -sf "$RIME_DIR" "$target"; then
                echo -e "  ${GREEN}✓ Symlink created${NC}"
            else
                echo -e "  ${RED}✗ Failed to create symlink${NC}"
            fi
        fi
    done
    echo ""
}

# 链接主题目录到 Fcitx5 目录
link_themes() {
    local themes_source="$RIME_DIR/themes"
    
    if [ -d "$themes_source" ]; then
        echo -e "${CYAN}Checking Fcitx5 theme symlinks...${NC}"
        
        # 目标主题目录列表
        local theme_targets=(
            "$HOME/.local/share/fcitx5/themes"
            "$HOME/.var/app/org.fcitx.Fcitx5/data/fcitx5/themes"
        )
        
        for target_dir in "${theme_targets[@]}"; do
            # 如果父目录存在，说明可能安装了该框架
            if [ -d "$(dirname "$target_dir")" ]; then
                mkdir -p "$target_dir"
                
                # 遍历源目录下的主题文件夹
                for theme_path in "$themes_source"/*; do
                    if [ -d "$theme_path" ]; then
                        local theme_name=$(basename "$theme_path")
                        local target_path="$target_dir/$theme_name"
                        
                        # 如果已存在（无论是链接还是实际目录），强制删除以确保覆盖
                        if [ -L "$target_path" ] || [ -e "$target_path" ]; then
                            if ! rm -rf "$target_path" 2>/dev/null; then
                                echo -e "  ${YELLOW}⚠ [skip theme]${NC} $theme_name, unable to remove existing target: $target_path"
                                continue
                            fi
                        fi
                        
                        # 创建软链接
                        if ln -sf "$theme_path" "$target_path"; then
                            echo -e "  ${GREEN}✓ [theme linked]${NC} $theme_name -> $target_dir"
                        else
                            echo -e "  ${RED}✗ [link failed]${NC} $theme_name"
                        fi
                    fi
                done
            fi
        done
        echo ""
    fi
}

# 检查并自动下载 jaroomaji 词库（如果已启用但缺少文件）
check_jaroomaji_files() {
    local jaroomaji_enabled=false
    local missing_files=0
    local dict_subdir="dicts.jp"
    
    # 检查是否在 default.custom.yaml 或 default.yaml 中启用了 jaroomaji
    if [ -f "$RIME_DIR/default.custom.yaml" ]; then
        if grep -q "^\s*-\s*schema:\s*jaroomaji" "$RIME_DIR/default.custom.yaml" 2>/dev/null; then
            jaroomaji_enabled=true
        fi
    fi
    
    if [ "$jaroomaji_enabled" = false ] && [ -f "$RIME_DIR/default.yaml" ]; then
        if grep -q "^\s*-\s*schema:\s*jaroomaji" "$RIME_DIR/default.yaml" 2>/dev/null; then
            jaroomaji_enabled=true
        fi
    fi
    
    if [ "$jaroomaji_enabled" = false ]; then
        return 0  # jaroomaji 未启用，无需检查
    fi
    
    # jaroomaji 已启用，检查必要的词库文件
    echo -e "${CYAN}Checking jaroomaji dictionary files...${NC}"
    
    # 需要检查的文件列表
    local required_files=(
        "jaroomaji.dict.yaml"
        "jaroomaji.kana_kigou.dict.yaml"
        "jaroomaji.mozc.dict.yaml"
        "jaroomaji.jmdict.dict.yaml"
        "jaroomaji.mozcemoji.dict.yaml"
        "jaroomaji.kanjidic2.dict.yaml"
    )
    
    # 检查每个文件是否存在
    for file in "${required_files[@]}"; do
        local check_path="$RIME_DIR/$file"
        if [ "$file" != "jaroomaji.dict.yaml" ]; then
            check_path="$RIME_DIR/$dict_subdir/$file"
        fi
        
        if [ ! -f "$check_path" ]; then
            missing_files=$((missing_files + 1))
            echo -e "${YELLOW}  ✗ Missing: $file${NC}"
        fi
    done
    
    # 如果缺少文件，自动下载
    if [ "$missing_files" -gt 0 ]; then
        echo -e "${YELLOW}⚠ Detected $missing_files missing jaroomaji dictionary file(s)${NC}"
        echo -e "${CYAN}Downloading missing files automatically...${NC}"
        echo ""
        
        local raw_base_url="https://raw.githubusercontent.com/lazyfoxchan/rime-jaroomaji/master"
        local curl_opts="-sSLf"
        
        # 检测系统类型并设置 curl 选项
        if [ "$(uname -s)" = "Darwin" ]; then
            if command -v /opt/homebrew/opt/curl/bin/curl >/dev/null 2>&1; then
                curl_cmd="/opt/homebrew/opt/curl/bin/curl $curl_opts"
            elif command -v /usr/local/opt/curl/bin/curl >/dev/null 2>&1; then
                curl_cmd="/usr/local/opt/curl/bin/curl $curl_opts"
            else
                curl_cmd="curl $curl_opts -k"
            fi
        else
            curl_cmd="curl $curl_opts"
        fi
        
        # 下载缺失的文件
        local downloaded=0
        for file in "${required_files[@]}"; do
            local dest_path="$RIME_DIR/$file"
            if [ "$file" != "jaroomaji.dict.yaml" ]; then
                dest_path="$RIME_DIR/$dict_subdir/$file"
                mkdir -p "$RIME_DIR/$dict_subdir"
            fi
            
            if [ ! -f "$dest_path" ]; then
                local url="$raw_base_url/$file"
                echo -e "${CYAN}  Downloading: $file${NC}"
                if eval "$curl_cmd \"$url\" -o \"$dest_path\"" 2>/dev/null; then
                    echo -e "${GREEN}  ✓ $file downloaded${NC}"
                    downloaded=$((downloaded + 1))
                    
                    # 如果是主词库文件，修正其引用路径
                    if [ "$file" == "jaroomaji.dict.yaml" ]; then
                        if [[ "$(uname)" == "Darwin" ]]; then
                            sed -i '' "s/  - jaroomaji/  - $dict_subdir\/jaroomaji/g" "$dest_path"
                        else
                            sed -i "s/  - jaroomaji/  - $dict_subdir\/jaroomaji/g" "$dest_path"
                        fi
                    fi
                else
                    # 为 macOS 重试 -k 选项
                    if [ "$(uname -s)" = "Darwin" ] && ! echo "$curl_cmd" | grep -q " -k"; then
                        if curl -sSLf -k "$url" -o "$dest_path" 2>/dev/null; then
                            echo -e "${GREEN}  ✓ $file downloaded (SSL skip)${NC}"
                            downloaded=$((downloaded + 1))
                            if [ "$file" == "jaroomaji.dict.yaml" ]; then
                                # 修正路径
                                sed -i '' "s/  - jaroomaji/  - $dict_subdir\/jaroomaji/g" "$dest_path"
                            fi
                        else
                            echo -e "${RED}  ✗ Failed to download $file${NC}"
                        fi
                    else
                        echo -e "${RED}  ✗ Failed to download $file${NC}"
                    fi
                fi
            fi
        done
        
        if [ "$downloaded" -gt 0 ]; then
            echo -e "${GREEN}✓ jaroomaji dictionary download complete ($downloaded file(s))${NC}"
            echo ""
        else
            echo -e "${YELLOW}⚠ Failed to download jaroomaji dictionary files, please check your network connection${NC}"
            echo ""
        fi
    else
        echo -e "${GREEN}✓ jaroomaji dictionary files are complete${NC}"
        echo ""
    fi
}

# 建立软链接
link_rime_config
link_themes

# 词库清理入口已禁用。
# 这套旧工具链依赖历史目录结构和已移除的词库文件，继续执行会破坏当前仓库。
dedup_dictionaries() {
    echo -e "${YELLOW}Skipping dictionary dedup/cleanup: this flow is disabled${NC}"
    echo ""
}

# 日语方案已移除，不再检查 jaroomaji 词库
dedup_dictionaries

echo ""
echo -e "${BLUE}Starting rebuild...${NC}"
echo ""

# 检测系统类型
OS_TYPE=$(uname -s)
DEPLOY_SUCCESS=false

# macOS (Squirrel)
if [ "$OS_TYPE" = "Darwin" ]; then
    echo -e "${YELLOW}Detected macOS, using the Squirrel deployment flow${NC}"
    echo ""
    
    # 方法3: 检查 Fcitx5-macOS
    FCITX5_APP="/Library/Input Methods/Fcitx5.app"
    if [ -d "$FCITX5_APP" ]; then
        echo -e "${GREEN}Detected Fcitx5-macOS${NC}"
        FCITX5_REMOTE="$FCITX5_APP/Contents/bin/fcitx5-remote"
        
        # 既然找到了 Fcitx5，我们就标记部署成功（指指令下达或提示完成）
        DEPLOY_SUCCESS=true
        
        echo -e "${YELLOW}Note: Fcitx5-macOS does not currently provide a CLI redeploy command${NC}"
        echo -e "${CYAN}Recommended steps:${NC}"
        echo -e "  1. Click the ${GREEN}Fcitx5 (penguin)${NC} icon in the menu bar"
        echo -e "  2. Choose \"Input Method Special Action\""
        echo -e "  3. Click \"Redeploy\""
        echo ""
        echo -e "${YELLOW}Or run the following command to restart Fcitx5 and force redeploy:${NC}"
        echo -e "  killall Fcitx5 && open -a \"$FCITX5_APP\""
    else
        # 只有在没找到 Fcitx5 时才显示 Squirrel 的警告
        echo -e "${YELLOW}⚠ Squirrel.app or Fcitx5.app was not found${NC}"
        echo -e "${CYAN}Please click \"Redeploy\" manually in the input method settings${NC}"
    fi


# Linux (Fcitx5)
elif [ "$OS_TYPE" = "Linux" ]; then
    echo -e "${YELLOW}Detected Linux, using the Fcitx5 deployment flow${NC}"
    echo ""
    
    # 检查并安装 Sarasa Mono SC 字体（如果未安装）
    if ! fc-list | grep -qi "sarasa mono sc"; then
        local_font_file="$RIME_DIR/sbzr.chrome.extension/fonts/SarasaMonoSC-Regular.ttf"
        if [ -f "$local_font_file" ]; then
            echo -e "${YELLOW}Sarasa Mono SC font not detected, installing...${NC}"
            mkdir -p "$HOME/.local/share/fonts"
            if cp "$local_font_file" "$HOME/.local/share/fonts/"; then
                fc-cache -f "$HOME/.local/share/fonts" 2>/dev/null
                echo -e "${GREEN}✓ Sarasa Mono SC font installed${NC}"
            else
                echo -e "${RED}✗ Failed to install font${NC}"
            fi
        else
            echo -e "${YELLOW}⚠ Font file not found: $local_font_file${NC}"
        fi
        echo ""
    fi
    
    if command -v rime_deployer &> /dev/null; then
        if [ -n "$SHARED_DATA_DIR" ]; then
            echo -e "${YELLOW}Running: rime_deployer --build $RIME_DIR $SHARED_DATA_DIR $BUILD_DIR${NC}"
        else
            echo -e "${YELLOW}Running: rime_deployer --build $RIME_DIR${NC}"
        fi
        echo ""
        
        # 编译并保存日志
        LOG_FILE="/tmp/rime_build_$(date +%Y%m%d_%H%M%S).log"
        if [ -n "$SHARED_DATA_DIR" ]; then
            rime_deployer --build "$RIME_DIR" "$SHARED_DATA_DIR" "$BUILD_DIR" 2>&1 | tee "$LOG_FILE"
        else
            rime_deployer --build "$RIME_DIR" 2>&1 | tee "$LOG_FILE"
        fi
        COMPILE_EXIT_CODE=${PIPESTATUS[0]}
        
        echo ""
        
        # 检查编译结果
        if [ "$COMPILE_EXIT_CODE" -eq 0 ]; then
            # 检查日志中的错误
            ERROR_COUNT=$(grep -c "error building config\|unresolved dependency\|ERROR" "$LOG_FILE" 2>/dev/null || echo "0")
            ERROR_COUNT=$(echo "$ERROR_COUNT" | tr -d '\n' | head -1)
            ERROR_COUNT=${ERROR_COUNT:-0}
            SCHEMA_RESULT=$(grep "finished updating schemas" "$LOG_FILE" 2>/dev/null | tail -1)
            
            if [ "$ERROR_COUNT" -eq 0 ] && [ -n "$SCHEMA_RESULT" ]; then
                echo -e "${GREEN}✓ Build completed${NC}"
                
                # 显示方案编译结果
                if echo "$SCHEMA_RESULT" | grep -q "finished updating schemas"; then
                    # 使用 sed 提取数字，兼容性更好
                    SUCCESS_COUNT=$(echo "$SCHEMA_RESULT" | sed -n 's/.*finished updating schemas: \([0-9]*\) success.*/\1/p' | head -1)
                    FAILURE_COUNT=$(echo "$SCHEMA_RESULT" | sed -n 's/.*\([0-9]*\) failure.*/\1/p' | head -1)
                    SUCCESS_COUNT=${SUCCESS_COUNT:-0}
                    FAILURE_COUNT=${FAILURE_COUNT:-0}
                    echo -e "${GREEN}  Schema build: ${SUCCESS_COUNT} succeeded, ${FAILURE_COUNT} failed${NC}"
                fi
                
                DEPLOY_SUCCESS=true
            else
                echo -e "${YELLOW}⚠ Build finished, but possible errors were detected${NC}"
                if [ "$ERROR_COUNT" -gt 0 ]; then
                    echo -e "${YELLOW}  Found $ERROR_COUNT error(s)${NC}"
                    echo ""
                    echo -e "${YELLOW}Key error messages:${NC}"
                    grep -E "error building config|unresolved dependency|ERROR" "$LOG_FILE" 2>/dev/null | tail -5 | while read line; do
                        echo -e "  ${RED}$line${NC}"
                    done
                fi
                DEPLOY_SUCCESS=true  # 即使有错误也继续，因为可能只是某些方案失败
            fi
            
            # 恢复扩展词库文件（如果备份存在且编译后的文件不存在）
            if [ -d "$BACKUP_DIR" ] && [ -d "$BUILD_DIR" ]; then
                RESTORED_FILES=$(find "$BACKUP_DIR" -type f 2>/dev/null)
                if [ -n "$RESTORED_FILES" ]; then
                    echo ""
                    echo -e "${YELLOW}Checking and restoring extended dictionary files...${NC}"
                    RESTORE_COUNT=0
                    while IFS= read -r backup_file; do
                        if [ -f "$backup_file" ]; then
                            RELATIVE_PATH="${backup_file#$BACKUP_DIR/}"
                            TARGET_FILE="$BUILD_DIR/$RELATIVE_PATH"
                            
                            # 如果目标文件不存在，则从备份恢复
                            if [ ! -f "$TARGET_FILE" ]; then
                                mkdir -p "$(dirname "$TARGET_FILE")"
                                if cp "$backup_file" "$TARGET_FILE" 2>/dev/null; then
                                    echo -e "  ${GREEN}✓ Restored: $(basename "$TARGET_FILE")${NC}"
                                    RESTORE_COUNT=$((RESTORE_COUNT + 1))
                                    EXTENDED_FILES_RESTORED=true
                                fi
                            fi
                        fi
                    done <<< "$RESTORED_FILES"
                    
                    if [ "$RESTORE_COUNT" -gt 0 ]; then
                        echo -e "${GREEN}✓ Extended dictionary restore complete ($RESTORE_COUNT file(s))${NC}"
                    else
                        echo -e "${YELLOW}  Extended dictionary files already exist or do not need restoration${NC}"
                    fi
                fi
                
                # 清理临时备份目录
                rm -rf "$BACKUP_DIR" 2>/dev/null
            fi
            
            # 如果编译后仍然缺少扩展词库文件，尝试从永久备份目录恢复
            if [ -d "$BUILD_DIR" ]; then
                PERMANENT_BACKUP_DIR="$RIME_DIR/resources"
                if [ -d "$PERMANENT_BACKUP_DIR" ]; then
                    # 检查 build 目录中是否缺少扩展词库文件
                    EXPECTED_FILES=("sbzr.extended.table.bin" "sbzr.extended.prism.bin" "sbzr.extended.reverse.bin")
                    MISSING_COUNT=0
                    for expected_file in "${EXPECTED_FILES[@]}"; do
                        if [ ! -f "$BUILD_DIR/$expected_file" ]; then
                            MISSING_COUNT=$((MISSING_COUNT + 1))
                        fi
                    done
                    
                    # 如果有缺失的文件，从永久备份目录恢复
                    if [ "$MISSING_COUNT" -gt 0 ]; then
                        PERMANENT_BACKUP_FILES=$(find "$PERMANENT_BACKUP_DIR" -name "*.extended.*" -type f 2>/dev/null)
                        if [ -n "$PERMANENT_BACKUP_FILES" ]; then
                            echo ""
                            echo -e "${YELLOW}Restoring extended dictionary files from the permanent backup directory...${NC}"
                            RESTORE_COUNT=0
                            while IFS= read -r backup_file; do
                                if [ -f "$backup_file" ]; then
                                    FILENAME=$(basename "$backup_file")
                                    TARGET_FILE="$BUILD_DIR/$FILENAME"
                                    if [ ! -f "$TARGET_FILE" ]; then
                                        if cp "$backup_file" "$TARGET_FILE" 2>/dev/null; then
                                            echo -e "  ${GREEN}✓ Restored from backup: $FILENAME${NC}"
                                            RESTORE_COUNT=$((RESTORE_COUNT + 1))
                                        fi
                                    fi
                                fi
                            done <<< "$PERMANENT_BACKUP_FILES"
                            if [ "$RESTORE_COUNT" -gt 0 ]; then
                                echo -e "${GREEN}✓ Extended dictionary restore complete ($RESTORE_COUNT file(s))${NC}"
                            fi
                        fi
                    fi
                fi
                
            fi
        else
            echo -e "${RED}✗ Build failed (exit code: $COMPILE_EXIT_CODE)${NC}"
            echo -e "${YELLOW}Detailed log saved to: $LOG_FILE${NC}"
            echo ""
            echo -e "${YELLOW}Key error messages:${NC}"
            grep -E "error building config|unresolved dependency|ERROR" "$LOG_FILE" 2>/dev/null | tail -10 | while read line; do
                echo -e "  ${RED}$line${NC}"
            done
            
            # 即使编译失败，也尝试恢复扩展词库文件
            if [ -d "$BACKUP_DIR" ] && [ -d "$BUILD_DIR" ]; then
                RESTORED_FILES=$(find "$BACKUP_DIR" -type f 2>/dev/null)
                if [ -n "$RESTORED_FILES" ]; then
                    echo ""
                    echo -e "${YELLOW}Attempting to restore extended dictionary files...${NC}"
                    RESTORE_COUNT=0
                    while IFS= read -r backup_file; do
                        if [ -f "$backup_file" ]; then
                            RELATIVE_PATH="${backup_file#$BACKUP_DIR/}"
                            TARGET_FILE="$BUILD_DIR/$RELATIVE_PATH"
                            mkdir -p "$(dirname "$TARGET_FILE")"
                            if cp "$backup_file" "$TARGET_FILE" 2>/dev/null; then
                                echo -e "  ${GREEN}✓ Restored: $(basename "$TARGET_FILE")${NC}"
                                RESTORE_COUNT=$((RESTORE_COUNT + 1))
                            fi
                        fi
                    done <<< "$RESTORED_FILES"
                    if [ "$RESTORE_COUNT" -gt 0 ]; then
                        echo -e "${GREEN}✓ Extended dictionary restore complete ($RESTORE_COUNT file(s))${NC}"
                    fi
                fi
                rm -rf "$BACKUP_DIR" 2>/dev/null
            fi
            
        fi
        
        # 保存日志文件路径供后续查看
        echo "$LOG_FILE" > /tmp/rime_last_build_log.txt 2>/dev/null
    else
        echo -e "${RED}Error: rime_deployer command not found${NC}"
        
        # 尝试检测发行版以提供更精准的建议
        if [ -f /etc/fedora-release ]; then
            echo -e "${YELLOW}Detected Fedora, please make sure fcitx5-rime and librime-tools are installed${NC}"
            echo -e "${YELLOW}Install command: sudo dnf install fcitx5-rime librime-tools${NC}"
        elif [ -f /etc/debian_version ]; then
            echo -e "${YELLOW}Detected Debian/Ubuntu, please make sure fcitx5-rime is installed${NC}"
            echo -e "${YELLOW}Install command: sudo apt install fcitx5-rime${NC}"
        elif [ -f /etc/arch-release ]; then
            echo -e "${YELLOW}Detected Arch Linux, please make sure fcitx5-rime and librime are installed${NC}"
            echo -e "${YELLOW}Install command: sudo pacman -S fcitx5-rime librime${NC}"
        else
            echo -e "${YELLOW}Please make sure the Rime deployment tool (rime_deployer) is installed${NC}"
        fi
    fi
fi

if [ "$DEPLOY_SUCCESS" = false ]; then
    echo ""
    echo -e "${YELLOW}⚠ Automatic deployment failed, please redeploy manually${NC}"
    echo -e "${CYAN}macOS: click \"Redeploy\" in Squirrel settings${NC}"
    echo -e "${CYAN}Linux: click \"Redeploy\" in Fcitx5 settings${NC}"
fi

echo ""
echo -e "${BLUE}Build Summary:${NC}"

# 检查 build 目录
if [ -d "$BUILD_DIR" ]; then
    BUILD_SIZE=$(du -sh "$BUILD_DIR" 2>/dev/null | cut -f1)
    BIN_COUNT=$(find "$BUILD_DIR" -name "*.bin" 2>/dev/null | wc -l)
    SCHEMA_COUNT=$(find "$BUILD_DIR" -name "*.schema.yaml" 2>/dev/null | wc -l)
    
    echo -e "  ${GREEN}Build directory size: $BUILD_SIZE${NC}"
    echo -e "  ${GREEN}Binary file count: $BIN_COUNT${NC}"
    echo -e "  ${GREEN}Schema file count: $SCHEMA_COUNT${NC}"
    
    # 列出主要的二进制文件
    echo ""
    echo -e "${BLUE}Main build artifacts:${NC}"
    # 优先显示扩展词库文件
    EXTENDED_BINS=$(find "$BUILD_DIR" -name "*.extended.*" -type f 2>/dev/null)
    if [ -n "$EXTENDED_BINS" ]; then
        echo "$EXTENDED_BINS" | while IFS= read -r file; do
            if [ -f "$file" ]; then
                SIZE=$(ls -lh "$file" 2>/dev/null | awk '{print $5}')
                echo -e "  ${GREEN}$SIZE $(basename "$file")${NC}"
            fi
        done
    fi
    # 然后显示其他二进制文件
    find "$BUILD_DIR" -name "*.bin" -type f ! -name "*.extended.*" -exec ls -lh {} \; 2>/dev/null | \
        awk '{printf "  %s %s\n", $5, $9}' | head -10
else
    if [ "$OS_TYPE" = "Darwin" ]; then
        echo -e "${YELLOW}  Note: redeploy manually to generate the build directory${NC}"
    else
        echo -e "${RED}  Build directory was not created; the build may have failed${NC}"
        exit 1
    fi
fi

echo ""
echo -e "${GREEN}========================================${NC}"
if [ "$DEPLOY_SUCCESS" = true ]; then
    echo -e "${GREEN}Rebuild complete${NC}"
else
    echo -e "${YELLOW}Build directory was cleaned; please redeploy manually${NC}"
fi
echo -e "${GREEN}========================================${NC}"
echo ""

# 根据系统类型提供不同的提示
OS_TYPE=$(uname -s)
if [ "$OS_TYPE" = "Darwin" ]; then
    echo -e "${YELLOW}macOS notes:${NC}"
    echo -e "${CYAN}  1. Open System Settings > Keyboard > Input Sources${NC}"
    echo -e "${CYAN}  2. Find \"Japanese Romaji\" or \"Rime\"${NC}"
    echo -e "${CYAN}  3. Right-click it > Redeploy${NC}"
    echo ""
    echo -e "${CYAN}  Or restart the app to trigger auto redeploy${NC}"
else
    echo -e "${YELLOW}Note: if the input method is not working properly, restart Fcitx5${NC}"
    echo -e "${YELLOW}Restart command: killall fcitx5 && fcitx5 &${NC}"
fi
