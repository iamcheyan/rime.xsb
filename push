#!/bin/bash
cd "$(dirname "$0")"

echo "Exporting dynamic_freq sync snapshot..."
python3 scripts/export-dynamic-freq.py || exit 1
echo "✓ dynamic_freq exported"
echo ""

echo "=== Managing files based on .gitignore ==="
echo ""

# 1. 找出应该被忽略但仍在 Git 中跟踪的文件，从 Git 中删除
echo "Checking for tracked files that should be ignored..."
REMOVED_COUNT=0
while IFS= read -r file; do
    if [ -n "$file" ] && [ "$file" != ".gitignore" ]; then
        if git check-ignore -q "$file" 2>/dev/null; then
            if git ls-files --error-unmatch "$file" >/dev/null 2>&1; then
                echo "  Removing: $file (ignored by .gitignore)"
                git rm --cached "$file" 2>/dev/null && REMOVED_COUNT=$((REMOVED_COUNT + 1))
            fi
        fi
    fi
done < <(git ls-files)

if [ "$REMOVED_COUNT" -gt 0 ]; then
    echo "✓ Removed $REMOVED_COUNT tracked file(s) that should be ignored"
else
    echo "✓ No tracked ignored files needed to be removed"
fi
echo ""

# # 2. 强制添加 userdb 文件（即使被 .gitignore 忽略）
# echo "添加 userdb 文件（强制添加）..."
# git add -f sbzr.userdb/*.ldb sbzr.userdb/lost/*.ldb 2>/dev/null || true
# git add -f jaroomaji.userdb/*.ldb jaroomaji.userdb/lost/*.ldb 2>/dev/null || true
# git add -f sync/*/*.txt 2>/dev/null || true
# git add -f sync/*/*.yaml 2>/dev/null || true
# echo "✓ userdb 和 sync 同步文件已强制添加"
# echo ""

# 3. 添加其他所有文件（遵循 .gitignore 规则）
echo "Adding remaining files..."
git add -A
echo "✓ Remaining files added"
echo ""

# 4. 显示最终状态
echo "=== File Status Summary ==="
TRACKED_COUNT=$(git ls-files | wc -l)
IGNORED_COUNT=$(git ls-files | xargs git check-ignore 2>/dev/null | wc -l)
echo "Tracked files: $TRACKED_COUNT"
echo "Tracked files that should be ignored: $IGNORED_COUNT"
echo ""

# 解析参数
FORCE_FLAG=""
ARGS=()

for arg in "$@"; do
    if [ "$arg" = "-f" ]; then
        FORCE_FLAG="--force"
    else
        ARGS+=("$arg")
    fi
done

# 5. 生成提交消息
DEVICE_NAME=$(hostname)
OS_NAME=$(uname -s)
if [ "$OS_NAME" = "Linux" ] && [ -f /etc/os-release ]; then
    OS_NAME=$(grep "^ID=" /etc/os-release | cut -d= -f2 | tr -d '"')
fi
# 组合标识符，例如: [CFSV9/fedora]
IDENTIFIER="$DEVICE_NAME/$OS_NAME"

if [ "${#ARGS[@]}" -gt 0 ]; then
    # 使用所有非 -f 参数作为消息（自动拼接，不需要引号）
    COMMIT_MSG="[$IDENTIFIER] ${ARGS[*]}"
else
    # 使用默认时间戳消息
    COMMIT_MSG="[$IDENTIFIER] Sync config to repo [$(date +"%Y%m%d_%H%M%S")]"
fi

# 打印提交消息
echo "=== Commit Message ==="
echo "$COMMIT_MSG"
echo ""

# 提交并推送
git commit --allow-empty -m "$COMMIT_MSG"

# 获取当前分支名
CURRENT_BRANCH=$(git branch --show-current)

# 检查当前分支是否有 upstream 关联
if ! git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1; then
    echo "Setting upstream for new branch: $CURRENT_BRANCH"
    git push $FORCE_FLAG --set-upstream origin "$CURRENT_BRANCH"
else
    git push $FORCE_FLAG
fi
